<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo2.upravlenie"
      style="-fx-padding: 20; -fx-background-color: #2c3e50;">

    <Label text="БАНКОМАТ" style="-fx-font-size: 24; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Separator/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Номер карты:" style="-fx-text-fill: white;"/>
        <TextField fx:id="cardNumberField" promptText="введите номер карты" prefWidth="200"/>
        <Button text="Вставить карту" onAction="#onInsertCard"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Label text="PIN-код:" style="-fx-text-fill: white;"/>
        <PasswordField fx:id="pinField" promptText="введите PIN" prefWidth="200"/>
        <Button text="Ввести PIN" onAction="#onEnterPin"/>
    </HBox>

    <Separator/>

    <Label text="ИНФОРМАЦИЯ" style="-fx-font-size: 16; -fx-text-fill: white; -fx-font-weight: bold;"/>
    <TextArea fx:id="infoArea" prefHeight="150" editable="false" wrapText="true"/>

    <Separator/>

    <Label text="ОПЕРАЦИИ" style="-fx-font-size: 16; -fx-text-fill: white; -fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER">
        <Button text="1. Снять наличные" onAction="#onWithdraw"/>
        <Button text="2. Перевод со счёта" onAction="#onTransfer"/>
        <Button text="3. Баланс" onAction="#onBalance"/>
        <Button text="4. История" onAction="#onHistory"/>
        <Button text="5. Завершить" onAction="#onExit"/>
    </HBox>

    <Button text="ОТМЕНА (0)" onAction="#onCancel" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>

    <Separator/>

    <TextArea fx:id="reportArea" prefHeight="150" editable="false" wrapText="true"/>

</VBox>